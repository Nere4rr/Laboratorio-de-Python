Accion SimuladorCajero Es
AMBIENTE
    RegCliente = REGISTRO
        nro_usuario : entero      
        pin : entero
        saldo : real
        limite_extraccion : real
        activo : logico           
    FIN_REGISTRO

    ArchClientes : Archivo de RegCliente Indexado por nro_usuario
    regCli : RegCliente

        ################
        Movimientos = REGISTRO
            nro_usuario: N(6)
            descripcion: AN(30)
        FR
           
        ArchMovimientos: Archivo de movimientos ordenado por nro_usuario 
        regMov: Movimientos
        #################


    usu_ingresado, pin_ingresado : entero
    intentos, opcion : entero
    monto, cuenta_destino : real
    acceso_concedido : logico
    cant_depositos, cant_extracciones, cant_transferencias : entero

    Procedimiento ConsultarSaldo() es
        ESC("Su saldo actual es: $", regCli.saldo)

        ################
        regMov.nro_usuario := regCli.nro_usuario
        regMov.descripcion := "Consulta de saldo"

        GRABAR(ArchMovimientos, regMov)
        #######################
    Fp
   


    Procedimiento Depositar_plata() es
        ESC("Ingrese el monto a depositar:")
        LEER(monto)

        SI monto > 0 ENTONCES
            regCli.saldo := regCli.saldo + monto 
            REGRABAR(ArchClientes, regCli) 
            cant_depositos := cant_depositos + 1
            
        ####################
            regMov.nro_usuario := regCli.nro_usuario
            regMov.descripcion := "Deposito"

            GRABAR(ArchMovimientos, regMov)

            ESC("Depósito exitoso.")
            ESC("Su saldo actual es: $", regCli.saldo)
        ####################

        Sino
            ESC("Error: Monto inválido.")
        Fin si
    Fin Procedimiento

    Procedimiento Extraer_plata() es
        ESC("Ingrese el monto a extraer:")
        LEER(monto)

        SI monto > regCli.limite_extraccion ENTONCES
            ESC("Error: Supera el límite diario de $", regCli.limite_extraccion)
        Sino 
            SI monto > regCli.saldo ENTONCES
                ESC("Error: Saldo insuficiente.")
            Sino
                SI monto > 0 ENTONCES
                    regCli.saldo := regCli.saldo - monto
                    REGRABAR(ArchClientes, regCli) 
                    cant_extracciones := cant_extracciones + 1

                    #################
                    regMov.nro_usuario := regCli.nro_usuario
                    regMov.descripcion := "Extraccion"

                    GRABAR(ArchMovimientos, regMov)

                    ESC("Extracción exitosa. Retire su dinero.")
                    ESC("Su saldo actual es: $", regCli.saldo)
                    ################

                Sino
                    ESC("Error: Monto inválido.")
                Fin si
            Fin Si
        Fin si
    Fin Procedimiento

    Procedimiento Transferir_plata() es
        ESC("Ingrese el CBU/Cuenta destino (sólo números):")
        LEER(cuenta_destino)

            //SI cuenta_destino <> 0 ENTONCES //sino ESC("Debe ingresar una cuenta válida.")
        ESC("Ingrese el monto a transferir:")
        LEER(monto)

        SI (//monto > 0 y ) monto > regCli.saldo ENTONCES
            ESC("Error: Saldo insuficiente.")
        Sino 
            SI monto > 0 ENTONCES
                regCli.saldo := regCli.saldo - monto
                REGRABAR(ArchClientes, regCli) 
                cant_transferencias := cant_transferencias + 1

                ################
                    regMov.nro_usuario := regCli.nro_usuario
                    regMov.descripcion := "Transferencia"

                    GRABAR(ArchMovimientos, regMov)

                    ESC("Transferencia exitosa a la cuenta ", cuenta_destino)
                    ESC("Su saldo actual es: $", regCli.saldo)
                ################

              
            Sino
                ESC("Error: Monto inválido.")
            Fin si
        Fin si                // se puede meter algo para ver si la cuenta es válida o no ¿
    Fin Procedimiento

    Procedimiento MostrarRegistro() es
        ESC("=== REGISTRO DE OPERACIONES DE LA SESIÓN ===")
        ESC("Depósitos: ", cant_depositos)
        ESC("Extracciones: ", cant_extracciones)
        ESC("Transferencias: ", cant_transferencias)
    Fin Procedimiento

############################
Procedimiento Mostrar_movimientos() es

        ESC("===MOVIMIENTOS DE LA SESIÓN ===")
        Abrir E/ (ArchMovimientos)
        LEER(ArchMovimientos, regMov)

        MIENTRAS NO FDA(ArchMovimientos) HACER

            SI regMov.nro_usuario = regCli.nro_usuario ENTONCES
                 ESC(regMov.descripcion)
            Fs

            LEER(ArchMovimientos, regMov)

        FM
        CERRAR(ArchMovimientos)
        ESC("Resumen de operaciones:")
        ESC("Depósitos: ", cant_depositos)
        ESC("Extracciones: ", cant_extracciones)
        ESC("Transferencias: ", cant_transferencias)
    Fp

############################################
PROCESO
    intentos := 0
    acceso_concedido := FALSO
    cant_depositos := 0
    cant_extracciones := 0
    cant_transferencias := 0

    Abrir E/S (ArchClientes)

    ESC("=== Bienvenido al Cajero Automático ===")

    MIENTRAS intentos < 3 Y acceso_concedido = FALSO HACER
        ESC("Ingrese su número de usuario:")
        LEER(usu_ingresado)
        ESC("Ingrese su PIN:")
        LEER(pin_ingresado)

        CLAVE := usu_ingresado
        LEER(ArchClientes, regCli)

        SI NFDA(ArchClientes) ENTONCES
            SI pin_ingresado = regCli.pin Y regCli.activo = VERDADERO ENTONCES
                acceso_concedido := VERDADERO
            Sino
                intentos := intentos + 1
                ESC("PIN incorrecto o cuenta inactiva. Intentos restantes: ", 3 - intentos)
            Fin si   
        Sino
            intentos := intentos + 1
            ESC("Usuario inexistente en la base de datos. Intentos restantes: ", 3 - intentos)
        Fin si
    FIN_MIENTRAS

    SI acceso_concedido ENTONCES
        REPETIR
            ESC("=== MENÚ PRINCIPAL ===")
            ESC("1. Consultar Saldo")
            ESC("2. Depositar")
            ESC("3. Extraer")
            ESC("4. Transferir")
            ESC("5. Ver Registro de Operaciones") // o ver resumen/movimientos
            ESC("6. Salir")
            ESC("Seleccione una opción:")
            LEER(opcion)

            SEGUN opcion HACER
                = 1: ConsultarSaldo()
                = 2: Depositar_plata()
                = 3: Extraer_plata()
                = 4: Transferir_plata()
                = 5: MostrarRegistro() //mostrar_movimientos()
                = 6: ESC("Gracias por operar con nosotros.")
            FIN_SEGUN

            SI opcion < 1 O opcion > 6 ENTONCES
                ESC("Opción no válida.")
            Fin si

        HASTA QUE opcion = 6
    Sino
        ESC("Cuenta bloqueada. Contacte a su banco.")
    Fin si

    CERRAR(ArchClientes)
    //CERRAR(archmovimientos)
FACCION


Procedimiento Iniciar_Sesion() es

    intentos := 0
    acceso := FALSO

    MIENTRAS intentos < 3 Y acceso = FALSO HACER

        ESC("Ingrese usuario:")
        LEER(usuario_ingresado)

        ESC("Ingrese PIN:")
        LEER(pin_ingresado)

        ABRIR E/S(ArchClientes)

        LEER(ArchClientes, regCli)

        MIENTRAS NO FDA(ArchClientes) Y regCli.nro_usuario <> usuario_ingresado HACER
            LEER(ArchClientes, regCli)
        FIN_MIENTRAS

        SI regCli.nro_usuario = usuario_ingresado ENTONCES

            SI regCli.pin = pin_ingresado ENTONCES
                acceso := VERDADERO
                ESC("Acceso concedido")
            SINO
                ESC("PIN incorrecto")
                intentos := intentos + 1
            FIN SI

        SINO
            ESC("Usuario no existe")
            intentos := intentos + 1
        FIN SI

    FIN_MIENTRAS

    RETORNAR acceso

FP

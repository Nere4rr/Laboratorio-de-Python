import json
import os

# --- AMBIENTE (Simulado) ---
# En Python no declaramos el ambiente explícitamente, pero definimos la constante del archivo.
ARCHIVO_USUARIOS = "usuarios.json"

def generar_archivo_prueba():
    """Crea un archivo físico con registros para poder probar el algoritmo."""
    if not os.path.exists(ARCHIVO_USUARIOS):
        datos_prueba = [
            {"id_usuario": "admin", "contraseña": "1234", "saldo": 50000.0, "nombre": "Administrador"},
            {"id_usuario": "user1", "contraseña": "0000", "saldo": 15000.0, "nombre": "Usuario Prueba"}
        ]
        with open(ARCHIVO_USUARIOS, 'w', encoding='utf-8') as f:
            json.dump(datos_prueba, f, indent=4)

def cajero_automatico():
    # Aseguramos que el archivo exista para la lectura
    generar_archivo_prueba()
    
    # Variables de trabajo en memoria interna
    intentos = 0
    cant_operaciones = 0
    sesion_valida = False
    reg_usuario = None  # Equivalente a RegUsuario: DATOS_USUARIO

    print("Bienvenido al Sistema de Cajero Automático")

    # Validación de acceso (Equivalente al Ciclo Repetir... Hasta que)
    while True:
        usuario_ingresado = input("Ingrese su identificador de usuario: ")
        pass_ingresada = input("Ingrese su contraseña: ")

        # Abrir E/(ArchUsuarios) y Leer todo el contenido a memoria
        try:
            with open(ARCHIVO_USUARIOS, 'r', encoding='utf-8') as f:
                arch_usuarios = json.load(f)
        except FileNotFoundError:
            arch_usuarios = []

        usuario_encontrado = False

        # Ciclo Pre-Test: Simula el Mientras NOFDA(ArchUsuarios) y usuario_encontrado = F hacer
        for registro in arch_usuarios:
            # Utilizamos el acceso por clave de diccionario para evaluar el registro actual
            if registro["id_usuario"] == usuario_ingresado and registro["contraseña"] == pass_ingresada:
                usuario_encontrado = True
                sesion_valida = True
                reg_usuario = registro # Guardamos el registro completo en memoria
                break # Rompe el for, simulando el fin de la búsqueda
        
        # Nota: El archivo se cierra automáticamente al salir del bloque 'with open...'
        # Esto equivale a Cerrar(ArchUsuarios)

        if not sesion_valida:
            intentos += 1
            print(f"Usuario o clave incorrectos. Intentos restantes: {3 - intentos}")

        # Condición de salida del Repetir (Hasta que sesion_valida = V O intentos = 3)
        if sesion_valida or intentos == 3:
            break

    # Flujo de operaciones si el usuario fue validado correctamente
    if sesion_valida:
        print(f"\nAcceso autorizado. Bienvenido/a al sistema, {reg_usuario['nombre']}")
        
        # Bucle del Menú Principal
        while True:
            print("\n--- MENÚ PRINCIPAL ---")
            print("1. Consultar saldo")
            print("2. Extraer dinero")
            print("3. Salir")
            
            try:
                opcion = int(input("Seleccione una opción: "))
            except ValueError:
                opcion = 0 # Manejo de error si ingresan texto en lugar de números

            # SEGÚN opcion HACER
            if opcion == 1:
                print(f"Su saldo actual es de: ${reg_usuario['saldo']:.2f}")
                cant_operaciones += 1
                
            elif opcion == 2:
                try:
                    monto = float(input("Ingrese el monto a extraer: "))
                except ValueError:
                    print("Error: Monto inválido.")
                    continue
                
                # Validación de fondos contra el campo del registro
                if monto > reg_usuario['saldo']:
                    print("Error: Fondos insuficientes.")
                else:
                    # Modificación destructiva del campo saldo en memoria interna
                    reg_usuario['saldo'] -= monto
                    print("Extracción realizada con éxito. Retire su dinero.")
                    cant_operaciones += 1
                    
            elif opcion == 3:
                print("Cerrando sesión de manera segura...")
                
            else:
                print("Error: Opción no válida.")

            # Condición de salida del Repetir (Hasta que opcion = 3)
            if opcion == 3:
                break
                
        print(f"\nCantidad de operaciones exitosas en esta sesión: {cant_operaciones}")
    else:
        print("\nCajero bloqueado temporalmente por seguridad.")

# Ejecución del programa
if __name__ == "__main__":
    cajero_automatico()

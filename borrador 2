ACCION CajeroAutomatico ES
AMBIENTE
   
    DATOS_USUARIO = Registro
        id_usuario: AN(10);
        contraseña: AN(4);
        saldo: numérico;
        nombre: AN(50);
    Fin Registro; 

 
    ArchUsuarios: Archivo de DATOS_USUARIO ordenado por id_usuario; 
    RegUsuario: DATOS_USUARIO; 

    
    monto: numérico
    usuario_ingresado, pass_ingresada: alfanumérico
    opcion, intentos, cant_operaciones: entero
    sesion_valida, usuario_encontrado: logico

PROCESO
    intentos := 0
    cant_operaciones := 0
    sesion_valida := F

    Esc("Bienvenido al Sistema de Cajero Automático")

    
    Repetir
        Esc("Ingrese su identificador de usuario:")
        Leer(usuario_ingresado)
        Esc("Ingrese su contraseña:")
        Leer(pass_ingresada)

        
        Abrir E/(ArchUsuarios) 
        
        
        Leer(ArchUsuarios, RegUsuario) 
        
        usuario_encontrado := F

        
        Mientras NOFDA(ArchUsuarios) y usuario_encontrado = F hacer 
            
            
            SI RegUsuario.id_usuario = usuario_ingresado y RegUsuario.contraseña = pass_ingresada ENTONCES 
                usuario_encontrado := V
                sesion_valida := V
            CONTRARIO
                
                Leer(ArchUsuarios, RegUsuario) 
            FIN SI
        FinMientras

        
        Cerrar(ArchUsuarios) 

        SI NO sesion_valida ENTONCES
            intentos := intentos + 1
            Esc("Usuario o clave incorrectos. Intentos restantes: ", 3 - intentos)
        FIN SI
    Hasta que sesion_valida = V O intentos = 3

    
    SI sesion_valida = V ENTONCES
        
        Esc("Acceso autorizado. Bienvenido/a al sistema, ", RegUsuario.nombre) 
        
        Repetir
            Esc("--- MENÚ PRINCIPAL ---")
            Esc("1. Consultar saldo")
            Esc("2. Extraer dinero")
            Esc("3. Salir")
            Leer(opcion)

            SEGÚN opcion HACER
                1:
                    
                    Esc("Su saldo actual es de: $", RegUsuario.saldo) 
                    cant_operaciones := cant_operaciones + 1
                2:
                    Esc("Ingrese el monto a extraer:")
                    Leer(monto)
                    
                    
                    SI monto > RegUsuario.saldo ENTONCES 
                        Esc("Error: Fondos insuficientes.")
                    CONTRARIO
                        
                        RegUsuario.saldo := RegUsuario.saldo - monto 
                        Esc("Extracción realizada con éxito. Retire su dinero.")
                        cant_operaciones := cant_operaciones + 1
                    FIN SI
                3:
                    Esc("Cerrando sesión de manera segura...")
                OTROS:
                    Esc("Error: Opción no válida.")
            FIN SEGUN
        Hasta que opcion = 3
        
        Esc("Cantidad de operaciones exitosas en esta sesión: ", cant_operaciones)
    CONTRARIO
        Esc("Cajero bloqueado temporalmente por seguridad.")
    FIN SI

FIN_ACCION
